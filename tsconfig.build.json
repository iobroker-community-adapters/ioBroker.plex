// Build-only tsconfig consumed by `build-adapter ts` (from @iobroker/adapter-dev).
// Emits compiled output to ./build/. Excludes test files.
{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "allowJs": false,
        "checkJs": false,
        "noEmit": false,
        "declaration": false,
        "inlineSources": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "src/**/*.test.ts"
    ]
}
