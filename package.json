{
  "name": "iobroker.plex",
  "version": "2.1.0",
  "description": "Integration of your Plex Media Server and / or your Tautulli",
  "author": "zefau <zefau@mailbox.org>",
  "contributors": [
    "zefau <zefau@mailbox.org>",
    "iobroker-community-adapters <iobroker-community-adapters@gmx.de>"
  ],
  "homepage": "https://github.com/iobroker-community-adapters/ioBroker.plex",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "plex",
    "tautulli",
    "media server"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iobroker-community-adapters/ioBroker.plex.git"
  },
  "bugs": {
    "url": "https://github.com/iobroker-community-adapters/ioBroker.plex/issues"
  },
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.15.2",
    "body-parser": "^2.2.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "tautulli-api": "^1.0.2",
    "uuid": "^14.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node22": "^22.0.2",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.12.2",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "eslint-plugin-unicorn": "^60.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "main": "build/main.js",
  "scripts": {
    "prebuild": "clean-dir ./build",
    "build": "build-adapter ts",
    "watch": "build-adapter ts --watch",
    "prebuild:ts": "clean-dir ./build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "check": "tsc --noEmit",
    "lint": "eslint -c eslint.config.mjs . --cache --cache-location .eslintcache --cache-strategy content",
    "test:ts": "mocha --config test/mocharc.custom.json src/**/*.test.ts",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:package",
    "verify": "npm run lint && npm run lint:admin && npm run build",
    "lint:admin": "cd src-admin && npm run lint",
    "translate": "translate-adapter",
    "npm:admin": "cd src-admin && npm i",
    "npm:www": "cd src-www && npm i",
    "build:admin": "cd src-admin && npm run build",
    "build:www": "cd src-www && npm run build",
    "build:all": "npm run build && npm run build:admin && npm run build:www",
    "dev:admin": "npm run build:admin && dev-server upload && dev-server watch",
    "dev:www": "cd src-www && npm run start",
    "release": "release-script"
  },
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "img/",
    "www/",
    "io-package.json",
    "LICENSE",
    "_ACTIONS.json",
    "_NODES.json",
    "_PLAYERDETAILS.json",
    "_SERVER_COMMANDS.json",
    "README.md",
    "README-states.md",
    "README-tautulli.md"
  ]
}
