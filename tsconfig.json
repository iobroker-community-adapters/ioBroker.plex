// Root tsconfig — settings for editor support and `tsc --noEmit` type checking.
// Compilation to ./build/ uses tsconfig.build.json (invoked by `build-adapter ts`).
{
    "extends": "@tsconfig/node22/tsconfig.json",
    "compilerOptions": {
        "noEmit": true,
        "allowJs": true,
        "checkJs": true,
        "outDir": "./build/",
        "removeComments": false,
        "resolveJsonModule": true,
        "sourceMap": true,
        "inlineSourceMap": false,
        "module": "preserve",
        "moduleResolution": "bundler",
        "noImplicitAny": true
    },
    "include": [
        "src/**/*.ts",
        "test/**/*.ts"
    ],
    "exclude": [
        "build/**",
        "node_modules/**",
        "src-admin/**",
        "src-www/**",
        "www/**",
        "admin/**"
    ]
}
